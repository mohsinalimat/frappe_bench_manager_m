		"@iconify/json": "^2.2.451",
		"@vitejs/plugin-vue": "^5.1.4",
		"@vitest/coverage-v8": "^2.1.8",
		"autoprefixer": "^10.4.2",
		"jsdom": "^25.0.1",
		"postcss": "^8.5.10",
		"postcss-font-display": "^0.3.0",
		"tailwindcss": "^3.4.15",
